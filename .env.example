# =============================================================================
# TutorBot Server Environment Variables
# =============================================================================
# Copy this file to .env and replace example values with deployment values.
# Required means the application fails at startup or the feature cannot work without a valid value. Optional means the application has a code default or the feature is disabled when the value is empty.

# =============================================================================
# Service Configuration
# =============================================================================

# ENV (optional, default: dev)
# Used for: Labels logs with the runtime environment.
# Accepted values: Any short environment name. Common values are dev, staging, prod, test, some identifier for you personally eg. mike.
# Consequences: Changing this does not change application behavior directly, but it changes the env label sent to Grafana. Use distinct values so logs from each deployment can be filtered correctly.
# Examples: dev, staging, prod, mike
ENV=dev

# PORT (optional, default: 3000)
# Used for: Selects the HTTP port the FastAPI server listens on and the Docker healthcheck probes.
# Accepted values: Integer TCP port numbers, typically 1024 to 65535 for normal users. Avoid ports already in use on the host.
# Consequences: Changing this changes the URL users and healthchecks must reach.
# Example: 3000 for local development, 8080 for platform hosted services.
PORT=3000

# =============================================================================
# Grafana Logging via Loki
# =============================================================================
# Grafana is the UI used to view and search logs. Loki is the log storage backend that receives logs from this server and makes them available in Grafana.

# LOKI_URL (required)
# Used for: Base URL of the Loki log storage service behind Grafana. The server appends /loki/api/v1/push.
# Accepted values: HTTP or HTTPS base URL for a Loki compatible endpoint.
# Consequences: Changing this sends structured logs to a different Loki backend, which changes where Grafana can query this service's logs. If missing, the application fails at startup. If invalid, the app keeps running but logs will not appear in Grafana.
# Examples: http://localhost:3100, https://loki.example.com
LOKI_URL=https://loki.example.com

# LOKI_USER (required)
# Used for: Basic authentication username for the Loki backend that Grafana reads from.
# Accepted values: Username expected by the Loki gateway or provider.
# Consequences: Changing this changes the identity used for log delivery. If missing, the application fails at startup. If invalid, logs will not be stored and therefore will not appear in Grafana.
# Examples: loki, tenant-user
LOKI_USER=your_username

# LOKI_PASSWORD (required)
# Used for: Basic authentication password for the Loki backend that Grafana reads from.
# Accepted values: Password or token expected by the Loki gateway or provider.
# Consequences: Changing this changes the secret used for log delivery. If missing, the application fails at startup. If invalid, logs will not be stored and therefore will not appear in Grafana.
# Example: your_loki_password_or_token
LOKI_PASSWORD=your_password

# LOKI_ORG_ID (required)
# Used for: Value sent in the X-Scope-OrgID header for multi-tenant Loki setups behind Grafana.
# Accepted values: Tenant or organization ID expected by the Loki provider.
# Consequences: Changing this routes logs to a different Loki tenant, which changes which Grafana tenant or data source can see them. If missing, the application fails at startup.
# Examples: tenant-a, 12345
LOKI_ORG_ID=your_org_id

# LOKI_LABELS (optional, default: empty)
# Used for: Adds static labels to every log stream so logs are easier to filter and group in Grafana.
# Accepted values: Comma separated key=value pairs. Keys and values are trimmed.
# Consequences: Changing labels affects Grafana log grouping and query filters. Avoid high cardinality labels such as request IDs or user IDs.
# Examples: region=us-east,version=1.0.0
# Automatically added labels include service_name and env. Per-record labels can include provider, model, class_selection, lesson, action_plan, and redacted_access_key.
LOKI_LABELS=

# LOKI_LABEL_* (optional, default: none)
# Used for: Adds individual static Loki labels for Grafana filtering. The part after LOKI_LABEL_ becomes a lowercase label name.
# Accepted values: Any environment variable whose name starts with LOKI_LABEL_.
# Consequences: Same as LOKI_LABELS. These labels are merged with LOKI_LABELS and affect Grafana log filters.
# Examples: LOKI_LABEL_REGION=us-east, LOKI_LABEL_VERSION=1.0.0

# =============================================================================
# Model Provider and Credentials
# =============================================================================

# MODEL_PROVIDER (optional, default: ANTHROPIC)
# Used for: Selects the LLM provider used by every request.
# Accepted values: ANTHROPIC, OPENAI, GOOGLE. The value is uppercased at startup.
# Consequences: Changing this switches which provider, API key, and model are used. The selected provider must have its matching API key configured.
MODEL_PROVIDER=ANTHROPIC

# ANTHROPIC_API_KEY (required when MODEL_PROVIDER=ANTHROPIC, otherwise optional)
# Used for: Authenticates Anthropic API requests.
# Accepted values: Anthropic API key.
# Consequences: Required for Anthropic. Changing this changes the account billed and the permissions available to Anthropic requests.
# Example: sk-ant-api03-example
ANTHROPIC_API_KEY=

# ANTHROPIC_MODEL (optional, default: claude-sonnet-4-6)
# Used for: Selects the Anthropic model when MODEL_PROVIDER=ANTHROPIC.
# Accepted values: Any Anthropic model ID available to the configured key.
# Consequences: Changing this affects response quality, latency, context limits, capabilities, and cost.
# Examples: claude-sonnet-4-6, claude-opus-4-7
ANTHROPIC_MODEL=

# OPENAI_API_KEY (required when MODEL_PROVIDER=OPENAI, otherwise optional)
# Used for: Authenticates OpenAI API requests.
# Accepted values: OpenAI API key.
# Consequences: Required for OpenAI. Changing this changes the account billed and the permissions available to OpenAI requests.
# Example: sk-proj-example
OPENAI_API_KEY=

# OPENAI_MODEL (optional, default: gpt-5.4)
# Used for: Selects the OpenAI model when MODEL_PROVIDER=OPENAI.
# Accepted values: Any OpenAI model ID available to the configured key.
# Consequences: Changing this affects response quality, latency, context limits, capabilities, and cost.
# Examples: gpt-5.4, gpt-4.1
OPENAI_MODEL=

# GOOGLE_API_KEY (required when MODEL_PROVIDER=GOOGLE, otherwise optional)
# Used for: Authenticates Google Gemini API requests.
# Accepted values: Google AI Studio API key from https://aistudio.google.com/apikey.
# Consequences: Required for Google. Changing this changes the Google project or account used for requests and billing.
# Example: AIzaSyExample
GOOGLE_API_KEY=

# GOOGLE_MODEL (optional, default: gemini-3.1-pro-preview)
# Used for: Selects the Google Gemini model when MODEL_PROVIDER=GOOGLE.
# Accepted values: Any Gemini model ID available to the configured key.
# Consequences: Changing this affects response quality, latency, context limits, capabilities, and cost.
# Examples: gemini-3.1-pro-preview, gemini-2.5-pro
GOOGLE_MODEL=

# =============================================================================
# LLM Generation and Request Controls
# =============================================================================

# MAX_TOKENS (optional, default: 10000)
# Used for: Maximum number of tokens the LLM may generate in one response.
# Accepted values: Positive integer within the selected model provider limit.
# Consequences: Higher values allow longer answers but can increase latency and cost. Lower values reduce cost and latency but can truncate responses.
# Examples: 2048, 4096, 10000
MAX_TOKENS=

# MAX_CONVERSATION_TOKENS (optional, default: 20000)
# Used for: Maximum estimated conversation size retained before trimming.
# Accepted values: Positive integer. The current SSR content limit is 50000, so values below 50000 produce a startup warning because SSR content can exceed the conversation retention limit.
# Consequences: Higher values preserve more context but increase token usage and latency. Lower values trim context sooner and can reduce answer continuity.
# Examples: 50000, 100000
MAX_CONVERSATION_TOKENS=

# MAX_RETRIES (optional, default: 2)
# Used for: Number of retry attempts for LLM requests.
# Accepted values: Non-negative integer.
# Consequences: Higher values can improve resilience to transient provider failures but increase worst case request duration. 0 disables retries.
# Examples: 0, 2, 5
MAX_RETRIES=

# TIMEOUT (optional, default: 300)
# Used for: LLM request timeout in seconds.
# Accepted values: Positive integer number of seconds.
# Consequences: Higher values allow long provider responses to complete but make users wait longer on stalled requests. Lower values fail faster but can cut off legitimate long responses.
# Examples: 60, 120, 300
TIMEOUT=

# TEMPERATURE (optional, default: 0.7)
# Used for: Sampling randomness for generated responses.
# Accepted values: Floating point number supported by the selected provider, commonly 0.0 to 2.0.
# Consequences: Lower values make responses more deterministic. Higher values make responses more varied but can reduce consistency.
# Examples: 0.0, 0.7, 1.0
TEMPERATURE=

# TOP_P (optional, default: provider default)
# Used for: Nucleus sampling parameter passed to the selected provider when set.
# Accepted values: Floating point number supported by the selected provider, commonly greater than 0.0 and up to 1.0.
# Consequences: Lower values constrain token choices and make output more focused. Higher values allow more variety. Leave empty unless tuning generation behavior.
# Examples: 0.8, 0.95, 1.0
TOP_P=

# FREQUENCY_PENALTY (optional, default: provider default)
# Used for: Penalizes tokens that already appeared in the generated text when the selected provider supports it.
# Accepted values: Floating point number supported by the selected provider. OpenAI commonly supports values from -2.0 to 2.0.
# Consequences: Higher values reduce repeated wording. Unsupported values can cause provider request errors.
# Examples: 0.0, 0.2, 1.0
FREQUENCY_PENALTY=

# PRESENCE_PENALTY (optional, default: provider default)
# Used for: Penalizes tokens based on whether they appeared at all when the selected provider supports it.
# Accepted values: Floating point number supported by the selected provider. OpenAI commonly supports values from -2.0 to 2.0.
# Consequences: Higher values encourage introducing new topics. Unsupported values can cause provider request errors.
# Examples: 0.0, 0.2, 1.0
PRESENCE_PENALTY=

# =============================================================================
# Optional Feature Configuration
# =============================================================================
# The following sections are optional features. Leave them disabled or empty unless you need cloud storage, status checks, or Mailgun email export.

# =============================================================================
# Optional: Cloud Mode, S3 Compatible Storage, and Status Indicator
# =============================================================================

# STATUS_PAGE_URL (optional, default: empty)
# Used for: Enables the client status indicator by deriving an Uptime Kuma base URL and status page slug.
# Accepted values: Full Uptime Kuma status page URL with a path segment slug.
# Supported URL patterns: https://status.example.com/status/tutorbot, https://status.example.com/tutorbot
# Consequences: Empty disables the status indicator. Changing this points status checks at a different public status page.
# Example: https://status.example.com/status/tutorbot
STATUS_PAGE_URL=

# CLOUD_MODE (optional, default: false in Python runtime, true in docker-compose)
# Used for: Chooses where class assets and conundrum files are read and written.
# Accepted values: true, false. The check is case sensitive, only true enables cloud mode. Any other value behaves as false.
# Consequences: true uses S3 compatible storage and requires every S3_BUCKET_* value below. false uses files from the local project filesystem and ignores S3_BUCKET_* values. In false mode, class and conundrum files are loaded relative to the process working directory, which is this repository root when run locally and /code inside the Docker image.
CLOUD_MODE=false

# S3_BUCKET_ENDPOINT (required when CLOUD_MODE=true, otherwise optional)
# Used for: The S3 compatible service endpoint used to create the S3 client.
# Accepted values: Fully qualified HTTP or HTTPS endpoint URL.
# Consequences: Changing this redirects all cloud asset reads and writes to a different S3 compatible service. An invalid endpoint prevents cloud mode from working.
# Examples: https://s3.amazonaws.com, https://minio.example.com
S3_BUCKET_ENDPOINT=

# S3_BUCKET_ACCESS_KEY (required when CLOUD_MODE=true, otherwise optional)
# Used for: Access key ID for authenticating S3 compatible requests.
# Accepted values: Provider generated access key string.
# Consequences: Changing this changes which S3 identity the server uses. The key must have read access for serving assets and write access for export flows that persist content.
# Examples: AKIAIOSFODNN7EXAMPLE, minioadmin
S3_BUCKET_ACCESS_KEY=

# S3_BUCKET_ACCESS_SECRET (required when CLOUD_MODE=true, otherwise optional)
# Used for: Secret key paired with S3_BUCKET_ACCESS_KEY.
# Accepted values: Provider generated secret access key string.
# Consequences: Changing this changes the credential secret used for S3. If it does not match the access key, cloud asset operations fail.
# Example: wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
S3_BUCKET_ACCESS_SECRET=

# S3_BUCKET_NAME (required when CLOUD_MODE=true, otherwise optional)
# Used for: Bucket containing class assets and other server managed files.
# Accepted values: Existing bucket name in the selected S3 compatible service.
# Consequences: Changing this points the application at a different asset store. Missing expected files cause class and lesson loading failures.
# Examples: tutorbot-assets, my-school-content
S3_BUCKET_NAME=

# S3_BUCKET_PATH (required when CLOUD_MODE=true, otherwise optional)
# Used for: Prefix inside S3_BUCKET_NAME where assets are stored.
# Accepted values: Non-empty path prefix without a leading slash when cloud mode is enabled. The current startup validation rejects an empty value in cloud mode.
# Consequences: Changing this changes the root folder used for S3 object keys. Use the prefix that contains the same asset structure as the local repository.
# Examples: tutorbot, schools/acme, prod/assets
S3_BUCKET_PATH=

# =============================================================================
# Optional: Mailgun Email Export
# =============================================================================

# MAILGUN_ENABLED (optional, default: false)
# Used for: Enables or disables email export of conversation summaries through Mailgun.
# Accepted values: true, false. The check is case sensitive, only true enables Mailgun. Any other value behaves as false.
# Consequences: true requires every MAILGUN_* value below and enables outbound email. false disables email export and the other MAILGUN_* values are ignored.
MAILGUN_ENABLED=false

# MAILGUN_API_KEY (required when MAILGUN_ENABLED=true, otherwise optional)
# Used for: Authenticates Mailgun API requests.
# Accepted values: Mailgun private API key for the sending domain.
# Consequences: Changing this changes the Mailgun credential used to send email. An invalid key causes email export failures.
# Example: key-0123456789abcdef0123456789abcdef
MAILGUN_API_KEY=

# MAILGUN_API_URL (required when MAILGUN_ENABLED=true, otherwise optional)
# Used for: Mailgun messages endpoint for the sending domain.
# Accepted values: Full Mailgun API URL for the domain messages endpoint.
# Consequences: Changing this changes the Mailgun domain or region used for outbound email. The API key must be valid for this endpoint.
# Examples: https://api.mailgun.net/v3/example.com/messages, https://api.eu.mailgun.net/v3/example.com/messages
MAILGUN_API_URL=

# MAILGUN_FROM_ADDRESS (required when MAILGUN_ENABLED=true, otherwise optional)
# Used for: Sender shown on exported conversation summary emails.
# Accepted values: RFC 5322 style email address, optionally with display name.
# Consequences: Changing this changes the From address recipients see. Mailgun may reject messages if the domain is not verified.
# Examples: TutorBot <noreply@example.com>, noreply@example.com
MAILGUN_FROM_ADDRESS="TutorBot <noreply@example.com>"
