# ENVIRONMENT (optional)
# Set the environment for the application (default: dev)
# Examples: dev, staging, prod
ENV=dev

# PORT (optional)
# HTTP port the server listens on (default: 3000)
PORT=3000

# =============================================================================
# Cloud Mode / S3 Storage
# =============================================================================
# CLOUD_MODE (required)
# Determines whether classes and conundrums are read from an S3-compatible
# bucket (Minio, AWS S3) or from the local filesystem.
#   - true:  fetch from S3. All S3_BUCKET_* variables below are required.
#   - false: fetch from the local filesystem. S3_BUCKET_* are ignored.
CLOUD_MODE=false

# S3_BUCKET_ENDPOINT (required when CLOUD_MODE=true)
# Base endpoint URL of the S3-compatible bucket (e.g. https://s3.example.com)
S3_BUCKET_ENDPOINT=

# S3_BUCKET_ACCESS_KEY (required when CLOUD_MODE=true)
# Access key ID for the bucket
S3_BUCKET_ACCESS_KEY=

# S3_BUCKET_ACCESS_SECRET (required when CLOUD_MODE=true)
# Secret access key for the bucket
S3_BUCKET_ACCESS_SECRET=

# S3_BUCKET_NAME (required when CLOUD_MODE=true)
# Bucket name holding the class assets
S3_BUCKET_NAME=

# S3_BUCKET_PATH (required when CLOUD_MODE=true)
# Path prefix inside the bucket (empty string for bucket root)
S3_BUCKET_PATH=""

# =============================================================================
# Mailgun (Email Export)
# =============================================================================
# Used to email conversation summaries to users. When MAILGUN_ENABLED=true,
# all MAILGUN_* variables below are required.

# MAILGUN_ENABLED (required)
#   - true:  enable email export via Mailgun
#   - false: disable email export; other MAILGUN_* vars are ignored
MAILGUN_ENABLED=false

# MAILGUN_API_KEY (required when MAILGUN_ENABLED=true)
# Mailgun API key for the sending domain
MAILGUN_API_KEY=

# MAILGUN_API_URL (required when MAILGUN_ENABLED=true)
# Mailgun messages endpoint (e.g. https://api.mailgun.net/v3/<domain>/messages)
MAILGUN_API_URL=

# MAILGUN_FROM_ADDRESS (required when MAILGUN_ENABLED=true)
# Sender address in RFC 5322 form: "Display Name <local@domain>"
MAILGUN_FROM_ADDRESS="Name <email@example.com>"

# LOKI LOGGING (required)
# Set the URL for Loki push endpoint for structured logging
# Example: http://localhost:3100
LOKI_URL=https://loki.example.com

# LOKI_USER (required)
# Username for basic authentication to Loki
LOKI_USER=your_username

# LOKI_PASSWORD (required)
# Password for basic authentication to Loki
LOKI_PASSWORD=your_password

# LOKI_ORG_ID (required)
# Organization ID for multi-tenant Loki setups
LOKI_ORG_ID=your_org_id

# LOKI_LABELS (optional)
# Comma-separated key=value pairs for additional Loki labels
# Note: service_name and env are set automatically at startup; provider, model,
# class_selection, lesson, action_plan, and redacted_access_key are attached
# per log record.
# Example: region=us-east,version=1.0.0
LOKI_LABELS=

# You can also set individual labels with LOKI_LABEL_* environment variables
# Example: LOKI_LABEL_REGION=us-east
# Example: LOKI_LABEL_VERSION=1.0.0

# =============================================================================
# Status Indicator Configuration (Optional)
# =============================================================================
# Uptime Kuma status page URL - base URL and slug are derived automatically
# Example: https://status.example.com/status/tutorbot
#   -> base_url: https://status.example.com
#   -> slug: tutorbot
STATUS_PAGE_URL=

# =============================================================================
# Model Configuration
# =============================================================================
# Each provider has its own API key and an optional comma-separated models
# list. At least one provider API key must be configured or the server will
# refuse to start. The first entry of each PROVIDER_MODELS list is that
# provider's default; if PROVIDER_MODELS is unset, the built-in default list
# is used. The server-side default provider (used when a request doesn't
# specify one) is the first provider in priority order (ANTHROPIC, OPENAI,
# GOOGLE) that has an API key configured. The UI picks per-request.

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODELS=claude-opus-4-7,claude-sonnet-4-6,claude-haiku-4-5

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODELS=gpt-5.4,gpt-5.4-mini,gpt-5.4-nano

# Google Gemini (uses Google AI Studio API key from https://aistudio.google.com/apikey)
# GOOGLE_API_KEY=AIza...
# GOOGLE_MODELS=gemini-3.1-pro-preview,gemini-3-flash-preview,gemini-3.1-flash-lite-preview

# MAX_TOKENS (optional)
# Set the maximum number of tokens to generate per LLM response (default: 10000)
MAX_TOKENS=

# MAX_CONVERSATION_TOKENS (optional)
# Maximum total tokens retained per conversation before trimming (default: 20000).
# Must be greater than the SSR content size limit.
MAX_CONVERSATION_TOKENS=

# MAX_RETRIES (optional)
# Set the maximum number of retries for LLM requests
MAX_RETRIES=

# TIMEOUT (optional)
# Timeout in seconds for LLM requests (default: 300)
TIMEOUT=

# TEMPERATURE (optional)
# Set the temperature for sampling
TEMPERATURE=

# TOP_P (optional)
# Set the nucleus sampling parameter
TOP_P=

# FREQUENCY_PENALTY (optional)
# Set the frequency penalty parameter
FREQUENCY_PENALTY=

# PRESENCE_PENALTY (optional)
# Set the presence penalty parameter
PRESENCE_PENALTY=

